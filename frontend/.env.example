# SignalCraft FE — Environment Variables Example
# Copy to .env.local and fill in actual values. DO NOT commit .env.local.

# ─── External Backend (Cloud Run, asia-northeast3) ──────────────────────────
VITE_API_URL=https://signalcraft-api-55721952249.asia-northeast3.run.app

# Cloud Run X-Auth-* headers (staging credentials below — replace for production)
VITE_X_AUTH_ID=poc_raven_0001
VITE_X_AUTH_PROVIDER=demo_provider
VITE_X_CUSTOMER_ID=12345678-1234-1234-1234-123456789012

# ─── Mock Toggle ────────────────────────────────────────────────────────────
# 'true' (or unset) → mockApi 사용 (개발 기본값)
# 'false' → 실제 Cloud Run 호출
VITE_USE_MOCK_API=true

# ─── Supabase (Frontend 직접 접근용, 현재 미사용) ─────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── App Meta ──────────────────────────────────────────────────────────────
VITE_APP_TITLE=SignalCraft
