# SignalCraft FE — Environment Variables Example
# Copy to .env.local and fill in actual values. DO NOT commit .env.local.

# ─── External Backend (FastAPI, staging) ───────────────────────────────────
# Staging serving API (활성)
VITE_API_URL=https://v1.api.stag.serving.signalcraft.kr

# Auth headers (staging credentials — replace for production)
# 모든 비공개 엔드포인트 호출 시 X-Auth-Id / X-Auth-Provider / X-Customer-ID 3종 필수.
VITE_X_AUTH_ID=poc_raven_0001
VITE_X_AUTH_PROVIDER=demo_provider
VITE_X_CUSTOMER_ID=12d5e33c-405a-4856-bf8e-51fc899c1737

# Default place_id (path param). /me 응답의 places[0].id 가 도착하기 전 fallback.
VITE_PLACE_ID=b33f995b-0e79-4551-afc4-e0c79238a18a

# ─── Mock Toggle ────────────────────────────────────────────────────────────
# 'true' (or unset) → mockApi 사용 (개발 기본값)
# 'false' → 실제 Cloud Run 호출
VITE_USE_MOCK_API=true

# ─── Per-Endpoint Mock Override ───
# 일부 엔드포인트만 실 API로 전환하려면 코드 상수로 제어 (env 변수 아님).
# frontend/src/lib/mockApi.ts 의 ENDPOINTS_DISABLED_IN_MOCK Set 에 path 추가.
# 백엔드 staging이 해당 path 완성되는 순서대로 set 에 추가 → 점진 전환.
# 예) 알림 백엔드 완성 시 '/notifications/', '/notifications/settings' 추가.

# ─── Supabase (Frontend 직접 접근용, 현재 미사용) ─────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── App Meta ──────────────────────────────────────────────────────────────
VITE_APP_TITLE=SignalCraft
VITE_CLIENT_THEME_ID=
